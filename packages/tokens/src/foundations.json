{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "space": {
    "$type": "dimension",
    "0": { "$value": { "value": 0, "unit": "px" } },
    "1": { "$value": { "value": 4, "unit": "px" } },
    "2": { "$value": { "value": 8, "unit": "px" } },
    "3": { "$value": { "value": 12, "unit": "px" } },
    "4": { "$value": { "value": 16, "unit": "px" } },
    "6": { "$value": { "value": 24, "unit": "px" } },
    "8": { "$value": { "value": 32, "unit": "px" } },
    "12": { "$value": { "value": 48, "unit": "px" } },
    "16": { "$value": { "value": 64, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": { "value": 0, "unit": "px" } },
    "sm": { "$value": { "value": 2, "unit": "px" } },
    "md": { "$value": { "value": 4, "unit": "px" } }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["PlemolJP Console NF", "monospace"] },
      "ui": { "$value": ["PlemolJP Console NF", "monospace"] },
      "mono": { "$value": ["PlemolJP Console NF", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "light": { "$value": 300 },
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    }
  },
  "motion": {
    "$type": "duration",
    "fast": { "$value": { "value": 120, "unit": "ms" } },
    "normal": { "$value": { "value": 220, "unit": "ms" } }
  }
}
