{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Hương — the Perfume River's clear, fresh jade beauty.",
  "meta": { "id": "huong", "label": "Huế Hương", "appearance": "dark" },
  "primitive": {
    "$type": "color",
    "ink": {
      "$value": { "colorSpace": "srgb", "components": [0.059, 0.114, 0.098], "hex": "#0F1D19" }
    },
    "stone": {
      "$value": { "colorSpace": "srgb", "components": [0.094, 0.165, 0.141], "hex": "#182A24" }
    },
    "pool": {
      "$value": { "colorSpace": "srgb", "components": [0.141, 0.306, 0.259], "hex": "#244E42" }
    },
    "rain": {
      "$value": { "colorSpace": "srgb", "components": [0.345, 0.443, 0.408], "hex": "#587168" }
    },
    "paper": {
      "$value": { "colorSpace": "srgb", "components": [0.839, 0.855, 0.816], "hex": "#D6DAD0" }
    },
    "ash": {
      "$value": { "colorSpace": "srgb", "components": [0.596, 0.647, 0.612], "hex": "#98A59C" }
    },
    "fog": {
      "$value": { "colorSpace": "srgb", "components": [0.424, 0.494, 0.463], "hex": "#6C7E76" }
    },
    "mist": {
      "$value": { "colorSpace": "srgb", "components": [0.541, 0.588, 0.557], "hex": "#8A968E" }
    },
    "jade": {
      "$value": { "colorSpace": "srgb", "components": [0.435, 0.816, 0.659], "hex": "#6FD0A8" }
    },
    "violet": {
      "$value": { "colorSpace": "srgb", "components": [0.663, 0.627, 0.784], "hex": "#A9A0C8" }
    },
    "gold": {
      "$value": { "colorSpace": "srgb", "components": [0.863, 0.733, 0.502], "hex": "#DCBB80" }
    },
    "vermilion": {
      "$value": { "colorSpace": "srgb", "components": [0.827, 0.518, 0.471], "hex": "#D38478" }
    },
    "blue": {
      "$value": { "colorSpace": "srgb", "components": [0.498, 0.729, 0.784], "hex": "#7FBAC8" }
    }
  },
  "semantic": {
    "$type": "color",
    "surface": {
      "canvas": { "$value": "{primitive.ink}" },
      "raised": { "$value": "{primitive.stone}" },
      "selected": { "$value": "{primitive.pool}" }
    },
    "text": {
      "primary": { "$value": "{primitive.paper}" },
      "secondary": { "$value": "{primitive.ash}" },
      "accent": { "$value": "{primitive.jade}" }
    },
    "border": { "subtle": { "$value": "{primitive.rain}" } },
    "accent": {
      "primary": { "$value": "{primitive.jade}" },
      "secondary": { "$value": "{primitive.violet}" }
    },
    "status": {
      "success": { "$value": "{primitive.jade}" },
      "info": { "$value": "{primitive.blue}" },
      "notice": { "$value": "{primitive.violet}" },
      "warning": { "$value": "{primitive.gold}" },
      "error": { "$value": "{primitive.vermilion}" }
    },
    "syntax": {
      "keyword": { "$value": "{primitive.violet}" },
      "string": { "$value": "{primitive.jade}" },
      "number": { "$value": "{primitive.gold}" },
      "function": { "$value": "{primitive.blue}" },
      "comment": { "$value": "{primitive.fog}" },
      "operator": { "$value": "{primitive.vermilion}" },
      "type": { "$value": "{primitive.blue}" },
      "constant": { "$value": "{primitive.gold}" },
      "property": { "$value": "{primitive.paper}" },
      "variable": { "$value": "{primitive.paper}" },
      "punctuation": { "$value": "{primitive.mist}" }
    }
  }
}
