{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Mưa — a deep dark mood shaped by Huế rain and wet stone.",
  "meta": { "id": "mua", "label": "Huế Mưa", "appearance": "dark" },
  "primitive": {
    "$type": "color",
    "ink": {
      "$value": { "colorSpace": "srgb", "components": [0.082, 0.098, 0.106], "hex": "#15191B" }
    },
    "stone": {
      "$value": { "colorSpace": "srgb", "components": [0.137, 0.157, 0.165], "hex": "#23282A" }
    },
    "pool": {
      "$value": { "colorSpace": "srgb", "components": [0.176, 0.275, 0.251], "hex": "#2D4640" }
    },
    "rain": {
      "$value": { "colorSpace": "srgb", "components": [0.357, 0.435, 0.412], "hex": "#5B6F69" }
    },
    "paper": {
      "$value": { "colorSpace": "srgb", "components": [0.812, 0.8, 0.761], "hex": "#CFCCC2" }
    },
    "ash": {
      "$value": { "colorSpace": "srgb", "components": [0.616, 0.639, 0.62], "hex": "#9DA39E" }
    },
    "fog": {
      "$value": { "colorSpace": "srgb", "components": [0.431, 0.498, 0.478], "hex": "#6E7F7A" }
    },
    "mist": {
      "$value": { "colorSpace": "srgb", "components": [0.545, 0.58, 0.561], "hex": "#8B948F" }
    },
    "jade": {
      "$value": { "colorSpace": "srgb", "components": [0.498, 0.722, 0.612], "hex": "#7FB89C" }
    },
    "violet": {
      "$value": { "colorSpace": "srgb", "components": [0.686, 0.639, 0.808], "hex": "#AFA3CE" }
    },
    "gold": {
      "$value": { "colorSpace": "srgb", "components": [0.851, 0.737, 0.541], "hex": "#D9BC8A" }
    },
    "vermilion": {
      "$value": { "colorSpace": "srgb", "components": [0.8, 0.502, 0.475], "hex": "#CC8079" }
    },
    "blue": {
      "$value": { "colorSpace": "srgb", "components": [0.518, 0.682, 0.753], "hex": "#84AEC0" }
    }
  },
  "semantic": {
    "$type": "color",
    "surface": {
      "canvas": { "$value": "{primitive.ink}" },
      "raised": { "$value": "{primitive.stone}" },
      "selected": { "$value": "{primitive.pool}" }
    },
    "text": {
      "primary": { "$value": "{primitive.paper}" },
      "secondary": { "$value": "{primitive.ash}" },
      "accent": { "$value": "{primitive.jade}" }
    },
    "border": { "subtle": { "$value": "{primitive.rain}" } },
    "accent": {
      "primary": { "$value": "{primitive.jade}" },
      "secondary": { "$value": "{primitive.violet}" }
    },
    "status": {
      "success": { "$value": "{primitive.jade}" },
      "info": { "$value": "{primitive.blue}" },
      "notice": { "$value": "{primitive.violet}" },
      "warning": { "$value": "{primitive.gold}" },
      "error": { "$value": "{primitive.vermilion}" }
    },
    "syntax": {
      "keyword": { "$value": "{primitive.violet}" },
      "string": { "$value": "{primitive.jade}" },
      "number": { "$value": "{primitive.gold}" },
      "function": { "$value": "{primitive.blue}" },
      "comment": { "$value": "{primitive.fog}" },
      "operator": { "$value": "{primitive.vermilion}" },
      "type": { "$value": "{primitive.blue}" },
      "constant": { "$value": "{primitive.gold}" },
      "property": { "$value": "{primitive.paper}" },
      "variable": { "$value": "{primitive.paper}" },
      "punctuation": { "$value": "{primitive.mist}" }
    }
  }
}
